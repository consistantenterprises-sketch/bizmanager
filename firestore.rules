rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuthenticated() && request.auth.token.role == 'admin';
    }
    function isBranchManager() {
      return isAuthenticated() && request.auth.token.role == 'branch_manager';
    }
    function isStockManager() {
      return isAuthenticated() && request.auth.token.role == 'stock_manager';
    }
    function isOwnBranch(branch) {
      return request.auth.token.branch == branch;
    }

    // All reads/writes go through the backend API (admin SDK bypasses rules)
    // These rules protect direct client access as a second security layer

    match /customers/{id} {
      allow read: if isAdmin() || (isBranchManager() && isOwnBranch(resource.data.branch));
      allow write: if isAdmin();
    }

    match /receipts/{id} {
      allow read: if isAdmin() || (isBranchManager() && isOwnBranch(resource.data.branch));
      allow write: if isAdmin();
    }

    match /expenses/{id} {
      allow read: if isAdmin() || (isBranchManager() && isOwnBranch(resource.data.branch));
      allow write: if isAdmin();
    }

    match /deposits/{id} {
      allow read: if isAdmin() || (isBranchManager() && isOwnBranch(resource.data.branch));
      allow write: if isAdmin();
    }

    match /stockEntries/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isStockManager();
    }

    match /transfers/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isStockManager();
    }

    match /bookings/{id} {
      allow read: if isAdmin() || (isBranchManager() && isOwnBranch(resource.data.branch));
      allow write: if isAdmin();
    }

    match /feedback/{id} {
      allow read: if isAdmin() || (isBranchManager() && isOwnBranch(resource.data.branch));
      allow write: if isAdmin();
    }

    match /employees/{id} {
      allow read, write: if isAdmin();
    }

    match /attendance/{id} {
      allow read: if isAdmin() || isBranchManager();
      allow write: if isAdmin() || isBranchManager();
    }

    match /config/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isStockManager();
    }
  }
}
